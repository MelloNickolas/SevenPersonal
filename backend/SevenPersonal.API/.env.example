# Copie este arquivo para .env e preencha os valores reais.
# O .env NÃO vai pro git (está no .gitignore).

# === Banco de dados ===
# Em produção: pegue do dashboard do Neon (https://neon.tech)
# Em dev local: pode ser um Postgres local ou o próprio Neon (free tier basta).
# Deixe vazio para cair no SQLite (arquivo seven.db).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# === Credenciais do admin ===
# São o usuário e senha que o cliente vai usar pra logar em /admin
ADMIN_USER=seven
ADMIN_PASSWORD=troque-esta-senha

# === Chave para assinar JWT ===
# Gere uma string aleatória longa (pelo menos 32 caracteres).
# Pode usar: openssl rand -base64 48
JWT_SECRET=cole-aqui-uma-string-aleatoria-muito-longa-de-pelo-menos-32-chars

# === Cloudinary (upload de imagens/vídeos) ===
# Pegue em https://cloudinary.com/console (Dashboard > Account Details)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret
CLOUDINARY_UPLOAD_FOLDER=seven-personal

# === CORS ===
# URL(s) do front em produção, separadas por vírgula.
# Em dev local pode deixar vazio (default = http://localhost:5173).
CORS_ORIGIN=http://localhost:5173
